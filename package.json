{
  "name": "streamlocal",
  "version": "1.0.0",
  "private": true,
  "description": "Local video streaming platform with HLS support",
  "scripts": {
    "dev": "concurrently \"pnpm --filter api dev\" \"pnpm --filter web dev\"",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "lint": "pnpm -r lint",
    "clean": "rm -rf apps/*/node_modules apps/*/.next apps/*/dist node_modules"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msgpackr-extract", "unrs-resolver"]
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
